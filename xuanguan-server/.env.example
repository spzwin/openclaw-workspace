# 服务配置
PORT=3000
WS_PORT=3001
HOST=0.0.0.0

# 应用配置（示例）
APP_ID=cli_xxxxxxxxxxxxxxxx
APP_SECRET=your_app_secret_here_change_in_production

# JWT 配置
JWT_SECRET=your_jwt_secret_change_in_production
JWT_EXPIRES_IN=2h

# 数据库配置（可选，使用内存存储时不需要）
# DATABASE_URL=postgresql://user:pass@localhost:5432/xuanguan

# 文件存储配置
MEDIA_STORAGE_PATH=/tmp/xuanguan/media
MEDIA_BASE_URL=http://localhost:3000/media

# 日志配置
LOG_LEVEL=info
LOG_FILE=/tmp/xuanguan/server.log

# 限流配置
RATE_LIMIT_PER_MINUTE=300
RATE_LIMIT_PER_HOUR=10000

# WebSocket 配置
WS_HEARTBEAT_INTERVAL=30000
WS_MAX_RECONNECT_CYCLES=10
